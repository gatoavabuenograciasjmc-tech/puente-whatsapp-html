<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Contactar por WhatsApp</title>

  <!-- Meta Pixel -->
  <script>
    !function(f,b,e,v,n,t,s){
      if(f.fbq)return;n=f.fbq=function(){
        n.callMethod ? n.callMethod.apply(n,arguments) : n.queue.push(arguments)
      };
      if(!f._fbq)f._fbq=n;
      n.push=n;
      n.loaded=!0;
      n.version='2.0';
      n.queue=[];
      t=b.createElement(e);
      t.async=!0;
      t.src=v;
      s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)
    }(window, document,'script','https://connect.facebook.net/en_US/fbevents.js');

    fbq('init', '1515966293431253');  // Tu Pixel real
    fbq('track', 'PageView');
  </script>

  <!-- Estilos del botón -->
  <style>
    body {
      font-family: sans-serif; 
      text-align: center; 
      margin-top: 50px; 
      background: #f0f8ff;
    }
    h2 {
      color: #333;
    }
    .whatsapp-btn {
      display: inline-block;
      padding: 18px 30px;
      font-size: 20px;
      font-weight: bold;
      background: linear-gradient(135deg, #25D366, #1ebe5d);
      color: white;
      border-radius: 12px;
      text-decoration: none;
      cursor: pointer;
      box-shadow: 0 5px 15px rgba(0,0,0,0.2);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .whatsapp-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 20px rgba(0,0,0,0.3);
    }
    .bounce {
      display: inline-block;
      animation: bounce 2s infinite;
    }
    @keyframes bounce {
      0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
      40% { transform: translateY(-8px); }
      60% { transform: translateY(-4px); }
    }
  </style>
</head>

<body>
  <h2>¡Conversemos por WhatsApp!</h2>
  <p>Haz clic en el botón para abrir WhatsApp y enviarme un mensaje:</p>

  <a href="https://api.whatsapp.com/send?phone=525571473883&text=¡Hola!%20Estoy%20interesado%20en%20contactarte" 
     target="_blank" 
     class="whatsapp-btn bounce"
     onclick="fbq('track', 'Contact');">
     💬 ¡Hola! Chatea conmigo
  </a>
</body>
</html>
